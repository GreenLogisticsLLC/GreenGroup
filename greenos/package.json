{
  "name": "@greenlogistics/greenos",
  "version": "1.0.0",
  "description": "Green OS — internal platform (Attendance, CRM, TMS, HR, …)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "deploy:build": "npm run db:generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.19.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  }
}
